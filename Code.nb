Notebook[{
Cell[BoxData[
 RowBox[{"\n", 
  RowBox[{
   RowBox[{
    RowBox[{"ClearAll", "[", "\"\<Global`*\>\"", "]"}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"a", " ", "=", " ", "1"}], ";"}], " ", "\n", 
   RowBox[{
    RowBox[{"b", " ", "=", " ", "1"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Phi0", " ", "=", " ", "1"}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"nMax", " ", "=", " ", "20"}], ";"}], "\n", 
