       "   ", 
       RowBox[{"Row", "[", 
        RowBox[{"{", "\n", "     ", 
         RowBox[{"\"\<Generando frame con x = \>\"", ",", "\n", "     ", 
          RowBox[{"NumberForm", "[", 
           RowBox[{"x", ",", " ", 
